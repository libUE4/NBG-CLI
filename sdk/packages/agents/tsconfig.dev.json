{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": "..",
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"paths": {
			"@cline/llms": ["../llms/src/index.ts"],
			"@cline/llms/*": ["../llms/src/*", "../llms/src/*/index.ts"],
			"@cline/shared": ["../shared/src/index.ts"],
			"@cline/shared/automation": ["../shared/src/automation/index.ts"],
			"@cline/shared/browser": ["../shared/src/index.browser.ts"],
			"@cline/shared/db": ["../shared/src/db/index.ts"],
			"@cline/shared/storage": ["../shared/src/storage/index.ts"],
			"@cline/shared/types": ["../shared/src/types/index.ts"],
			"@cline/shared/*": ["../shared/src/*", "../shared/src/*/index.ts"]
		}
	}
}
